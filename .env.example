# --------------------------------------
# Vercel → GitHub Relay Environment
# --------------------------------------

# Secret used to verify Vercel webhook signatures
VERCEL_WEBHOOK_SECRET=your-strong-shared-secret

# GitHub repository info
GH_OWNER=your-org-or-username
GH_REPO=your-repo-name

# GitHub App configuration
# The numeric App ID (from the GitHub App settings page)
GH_APP_ID=123456

# ⚠️ In Vercel/ENV, make sure line breaks are escaped as \n
GH_APP_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEv...\n-----END PRIVATE KEY-----"